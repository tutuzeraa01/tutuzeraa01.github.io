<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ElRosado - Restaurante Mexicano</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
      scroll-behavior: smooth;
    }

    body {
      background: #111;
      color: #fff;
    }

    nav {
      position: fixed;
      width: 100%;
      top: 0;
      background: rgba(0,0,0,0.8);
      padding: 15px 50px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 1000;
    }

    nav h2 {
      color: #ff3c00;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 20px;
    }

    nav ul li {
      cursor: pointer;
    }

    nav ul li:hover {
      color: #ff3c00;
    }

    header {
      height: 100vh;
      background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.8)),
      url('https://images.unsplash.com/photo-1600891964599-f61ba0e24092');
      background-size: cover;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    header h1 {
      font-size: 4rem;
      color: #ff3c00;
    }

    button {
      margin-top: 20px;
      padding: 12px 25px;
      border: none;
      background: #ff3c00;
      color: white;
      border-radius: 5px;
      cursor: pointer;
    }

    section {
      padding: 80px 50px;
    }

    .menu-items {
      display: none;
      margin-top: 30px;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

    .menu-items.active {
      display: grid;
    }

    .card {
      background: #1a1a1a;
      padding: 20px;
      border-radius: 10px;
      cursor: pointer;
      transition: 0.3s;
    }

    .card:hover {
      background: #222;
      transform: scale(1.05);
    }

    .card p {
      display: none;
      margin-top: 10px;
      font-size: 0.9rem;
    }

    .card.active p {
      display: block;
    }

    footer {
      text-align: center;
      padding: 20px;
      background: black;
      opacity: 0.7;
    }
  </style>
</head>

<body>

<nav>
  <h2>ElRosado</h2>
  <ul>
    <li onclick="scrollToSection('home')">Início</li>
    <li onclick="scrollToSection('menu')">Menu</li>
    <li onclick="scrollToSection('contato')">Contato</li>
  </ul>
</nav>

<header id="home">
  <h1>ElRosado</h1>
  <p>Experiência Mexicana Premium</p>
  <button onclick="scrollToSection('menu')">Ver Menu</button>
</header>

<section id="menu">
  <h2>Nosso Menu</h2>
  <button onclick="toggleMenu()">Mostrar / Esconder Cardápio</button>

  <div class="menu-items" id="menuItems">

    <div class="card" onclick="toggleCard(this)">
      <h3>Tacos 🌮</h3>
      <p>Carne, frango ou vegetariano com molho especial.</p>
    </div>

    <div class="card" onclick="toggleCard(this)">
      <h3>Burritos 🌯</h3>
      <p>Recheados com arroz, feijão e carnes temperadas.</p>
    </div>

    <div class="card" onclick="toggleCard(this)">
      <h3>Nachos 🧀</h3>
      <p>Com cheddar, guacamole e jalapeños.</p>
    </div>

    <div class="card" onclick="toggleCard(this)">
      <h3>Guacamole 🥑</h3>
      <p>Feito na hora com ingredientes frescos.</p>
    </div>

  </div>
</section>

<section id="contato">
  <h2>Contato</h2>
  <p>📍 Curitiba - PR</p>
  <p>📞 (41) 99999-9999</p>
</section>

<footer>
  <p>© 2026 ElRosado</p>
</footer>

<script>
  function scrollToSection(id) {
    document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
  }

  function toggleMenu() {
    document.getElementById('menuItems').classList.toggle('active');
  }

  function toggleCard(card) {
    card.classList.toggle('active');
  }
</script>

</body>
</html>
